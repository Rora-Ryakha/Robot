# Порты для служб. Все на локалхосте, в том числе графана - до неё доступ через nginx. Рекомендую в конфиге nginx добавить allow your-ip и deny all.
LOKI_PORT=127.0.0.1:3100
PROMETHEUS_PORT=127.0.0.1:9090
GRAFANA_PORT=127.0.0.1:3000
NGINX_LISTEN_PORT=80
# Ключи от админки графаны
GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=
