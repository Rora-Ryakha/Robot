# Данные NATS. Имя хоста взято в соответствии с именем контейнера. Решите менять - меняйте и stateful/docker-compose.yml
NATS_HOST=nats
NATS_PORT=4222
# Порт, на котором будет FastAPI для приёма запросов от Prometheus.
FASTAPI_PORT=8080
# Настройка уровня логирования. Важно, чтобы она совпадала с типами логов модуля logging
VERBOSITY=INFO
