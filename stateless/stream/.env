# Данные NATS
NATS_HOST=nats
NATS_PORT=4222
# Уровень логирования. Должен совпадать с уровнями из модуля logging
VERBOSITY=INFO
# API-ключи Bybit
API_KEY=
API_SECRET=
# Используем ли демо.
DEMO=True
# Используем ли тестнет. Если DEMO=True, оставить False
TESTNET=False
# Интервал синхронизациисписка тикеров с биржей в минутах
UPDATE_INTERVAL_MIN=240
