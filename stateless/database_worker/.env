# Данные БД. Имя хоста взято в соответствии с именем контейнера. Решите менять - меняйте и stateful/docker-compose.yml
DB_HOST=postgres
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=
# Данные NATS. Рекомендации аналогичны тем, что выше.
JETSTREAM_HOST=jetstream
JETSTREAM_PORT=4223
NATS_HOST=nats
NATS_PORT=4222
# Настройка уровня логирования. Важно, чтобы она совпадала с типами логов модуля logging
VERBOSITY=INFO
# Порт, на котором будет FastAPI для приёма запросов к БД от тг-бота
FASTAPI_PORT=8080
