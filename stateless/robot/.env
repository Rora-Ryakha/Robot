# Данные NATS
NATS_HOST=nats
NATS_PORT=4222
JETSTREAM_HOST=jetstream
JETSTREAM_PORT=4223
# Уровень логов. Должен совпадать с уровнями логов из модуля logging
VERBOSITY=INFO
# API keys Bybit
API_KEY=
API_SECRET=
# Пути к файлам с моделями.
BUY_MODEL_PATH=
SELL_MODEL_PATH=
# Настройки робота.
# Размер позиции в долларах по умолчанию. Реальная доля средств в позиции будет равна этому числу, делённому на LEVERAGE_SIZE
DEFAULT_POSITION_SIZE_USDT=3000
# Размер плеча. Для отключения плеч использовать 1.0
LEVERAGE_SIZE=5.0
# Порог для модели на покупку, выше которого считать предикт равным 1
BUY_THRESHOLD=0.9
# Порог для модели на продажу, выше которого считать предикт равным 1
SELL_THRESHOLD=0.9
# Фильтр по объёму предыдущей свечи. Если объём меньше - в сделку не идём
MIN_VOLUME_USDT=10000
# Использовать ли демо на Bybit.
DEMO=True
# Использовать ли Testnet на Bybit. Если DEMO=True, то оставить False
TESTNET=False
